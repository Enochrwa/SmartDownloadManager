{
  "name": "smart-download-manager",
  "private": true,
  "version": "0.1.0",
  "description": "Universal, cross-platform, open-source download manager — HTTP/FTP/SFTP/WebDAV/BitTorrent/Metalink/HLS/DASH and thousands of video sites, one engine.",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev --filter=@sdm/desktop",
    "build": "turbo run build",
    "tauri": "pnpm --filter @sdm/desktop tauri",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0+sha512.b4106707c7225b1748b61595953ccbebff97b54ad05d002aa3635f633b9c53cd666f7ce9b8bc44704f1fa048b9a49b55371ab2d9e9d667d1efe2ef1514bcd513"
}
