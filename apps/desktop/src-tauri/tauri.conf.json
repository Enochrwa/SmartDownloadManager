{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartDownloadManager",
  "version": "0.1.0",
  "identifier": "com.smartdownloadmanager.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SmartDownloadManager",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage", "deb"],
    "icon": []
  }
}
