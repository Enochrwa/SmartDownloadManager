{
  "manifest_version": 3,
  "name": "SmartDownloadManager",
  "version": "0.11.0",
  "description": "Send downloads, right-clicked links, copied URLs, and pasted link lists straight to SmartDownloadManager instead of the browser's built-in downloader.",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@smartdownloadmanager.app",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "downloads",
    "contextMenus",
    "storage",
    "notifications",
    "alarms",
    "clipboardRead"
  ],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartDownloadManager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
